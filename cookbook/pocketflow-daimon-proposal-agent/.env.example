OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Optional: set this only if you run the script from another directory.
# DAIMON_DATA_DIR=../../data_daimon

# Optional: OCR is off by default because some Docling/OCR model stacks fail
# with errors such as "Unsupported configuration: torch.PP-OCRv6.det.small".
# Enable only if your PDFs are scans and your Docling OCR backend is working.
DAIMON_DOCLING_OCR=false
